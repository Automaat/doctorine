# Database
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgresql://doctorine:replace-with-strong-password@localhost:5434/doctorine

# Backend
DOCTORINE_ADDR=:8000
DOCTORINE_JWT_SECRET=replace-with-long-random-secret
DOCTORINE_ADMIN_USERNAME=admin
DOCTORINE_ADMIN_PASSWORD=replace-with-strong-admin-password
# false for local HTTP dev; production compose defaults to true (needs HTTPS ORIGIN)
DOCTORINE_COOKIE_SECURE=false
DOCTORINE_UPLOAD_DIR=./data/uploads
CORS_ORIGINS=http://localhost:5175,http://127.0.0.1:5175,http://localhost:3001,http://127.0.0.1:3001

# Frontend
NODE_ENV=development
ORIGIN=http://localhost:3001
PUBLIC_API_URL=http://localhost:8010
API_PROXY_TARGET=http://localhost:8010
